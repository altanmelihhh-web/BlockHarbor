# HTTP port the container binds to on the host
HTTP_PORT=8090

# Admin login credentials
# Default: username=admin, password=admin (change immediately after first login)
CWE_ADMIN_USERNAME=admin
# Leave blank to use default "admin" password (NOT for production)
# Generate: php -r "echo password_hash('YOUR_PASSWORD', PASSWORD_BCRYPT) . \"\\n\";"
CWE_ADMIN_PASSWORD_HASH=

# REST API keys (JSON array). Leave blank to use placeholder dev key.
# Example: [{"key":"your-48-char-hex","role":"admin","owner":"my-tool"}]
CWE_API_KEYS=

# VirusTotal v3 API key (optional — enrichment.php VT lookups)
CWE_VT_API_KEY=

# GreyNoise community API key (optional — 50 lookups/day free tier)
CWE_GREYNOISE_API_KEY=

# ipgeolocation.io API key (optional — IP geolocation enrichment)
CWE_IPGEOLOCATION_API_KEY=

# Contact email shown in TAXII 2.1 discovery endpoint
CWE_CONTACT_EMAIL=admin@example.com

# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8090
APP_TIMEZONE=UTC

# Docker quickstart HTTP port (8080 too commonly conflicted; bin/docker-up.sh
# detects collisions and prompts for an alternate). Production deploys
# terminate TLS at an upstream reverse proxy.
HTTP_PORT=8090

# Database — runtime app role (DML only after migrations)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=blockharbor
DB_USER=blockharbor_app
DB_PASSWORD=change-me-strong-random
DB_SSLMODE=prefer

# Database — migrator role (DDL; used by phinx only)
DB_MIGRATOR_USER=blockharbor_migrator
DB_MIGRATOR_PASSWORD=change-me-strong-random

# Session
SESSION_NAME=BLOCKHARBOR_SESSION
SESSION_LIFETIME=1800
SESSION_ABSOLUTE_LIFETIME=28800
# false for HTTP-only Docker quickstart; MUST be true in TLS production
SESSION_COOKIE_SECURE=false

# Password policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_MIXED_CASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_HISTORY_COUNT=5

# Lockout
LOGIN_MAX_FAILS_PER_IP_5MIN=10
LOGIN_MAX_FAILS_PER_USER_1H=5
LOGIN_LOCKOUT_MINUTES=15

# Encryption (32-byte hex — generate via: openssl rand -hex 32)
APP_KEY=change-me-32-byte-random-hex

# Logging
LOG_PATH=/var/log/blockharbor/app.log
LOG_LEVEL=info

# Backups (referenced by P7 backup runbook)
BACKUP_DIR=/var/backups/blockharbor

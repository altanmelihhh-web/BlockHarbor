#!/usr/bin/env bash
#
# BlockHarbor — audit chain verifier
#
# Usage:
#   bin/verify-audit-chain                       # verify entire chain
#   bin/verify-audit-chain --since "2026-01-01"  # only from that date
#   bin/verify-audit-chain --quiet               # only error output
#   bin/verify-audit-chain --json                # JSON output
#
# Exit 0 = chain intact; 1 = mismatch detected.
# Suitable for cron monitoring (registered weekly Sunday 04:00 by installer).

set -euo pipefail
cd "$(dirname "$0")/.."

if [[ $EUID -eq 0 ]]; then
    export COMPOSER_ALLOW_SUPERUSER=1
fi

php -d display_errors=on bin/verify-audit-chain.php "$@"

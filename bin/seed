#!/usr/bin/env bash
#
# BlockHarbor — Phinx seeder runner (host mode)
# Usage:
#   ./bin/seed                       # run all seeders
#   ./bin/seed -s DefaultUserSeeder  # only one

set -euo pipefail
cd "$(dirname "$0")/.."

if [[ $EUID -eq 0 ]]; then
    export COMPOSER_ALLOW_SUPERUSER=1
fi

# Export .env so seeders can read INITIAL_ADMIN_* via getenv()
if [[ -r .env ]]; then
    set -a; . ./.env; set +a
fi

if [[ $# -eq 0 ]]; then
    exec vendor/bin/phinx seed:run
fi
exec vendor/bin/phinx seed:run "$@"
